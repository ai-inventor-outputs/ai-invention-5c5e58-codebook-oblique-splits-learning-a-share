\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Accuracy/$R^2$ vs.\ codebook size $K$ for six representative datasets. Clear elbows at $K = 3$--$5$ confirm that small codebooks capture the essential decision structure. Horizontal dashed lines show FIGS baselines; vertical dashed line marks the typical elbow region.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:accuracy_vs_k}{{3}{9}{Accuracy/$R^2$ vs.\ codebook size $K$ for six representative datasets. Clear elbows at $K = 3$--$5$ confirm that small codebooks capture the essential decision structure. Horizontal dashed lines show FIGS baselines; vertical dashed line marks the typical elbow region}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Radar chart of interpretability metrics across five domain-semantic datasets. California\_housing and diabetes\_pima achieve the highest sparsity and domain alignment, while heart\_disease shows the highest direction diversity but lower domain alignment.}}{10}{figure.4}\protected@file@percent }
\newlabel{fig:interpretability_radar}{{4}{10}{Radar chart of interpretability metrics across five domain-semantic datasets. California\_housing and diabetes\_pima achieve the highest sparsity and domain alignment, while heart\_disease shows the highest direction diversity but lower domain alignment}{figure.4}{}}
