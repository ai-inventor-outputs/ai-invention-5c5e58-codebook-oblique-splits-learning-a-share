\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Three-component diagnostic gap decomposition. Gap~A (oblique split quality, $d = 0.70$) and Gap~C (optimizer sensitivity) are the true bottlenecks, while Gap~B (codebook constraint, $p = 0.43$) is not statistically significant---establishing that the codebook constraint is free.}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:gap_decomposition}{{2}{8}{Three-component diagnostic gap decomposition. Gap~A (oblique split quality, $d = 0.70$) and Gap~C (optimizer sensitivity) are the true bottlenecks, while Gap~B (codebook constraint, $p = 0.43$) is not statistically significant---establishing that the codebook constraint is free}{figure.2}{}}
